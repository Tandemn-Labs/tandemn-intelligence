# Koi agent LLM provider: "openrouter" (default) or "anthropic"
KOI_LLM_PROVIDER=openrouter

# --- OpenRouter / OpenAI-compatible path (default) ---
KOI_BASE_URL=https://openrouter.ai/api/v1
KOI_AGENT_MODEL=deepseek/deepseek-chat
KOI_API_KEY=sk-or-...

# --- Anthropic direct path (set KOI_LLM_PROVIDER=anthropic) ---
# KOI_AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# Tandem internal metrics API — used by TandemMetricsAPISource
TANDEM_METRICS_API_URL=http://localhost:8080
TANDEM_METRICS_API_KEY=

# Optional: vLLM Prometheus endpoint (if using VLLMPrometheusSource)
VLLM_METRICS_URL=http://localhost:8000
